<div class="w-full flex flex-col min-h-screen">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl text-white">Welcome back, <%= current_user.email_address.split('@').first.capitalize %>!</h1>
    <div class=" font-mono tracking-wide text-sm text-white">
      <%= Time.now.strftime("%A, %B %d, %Y") %>
    </div>
  </div>
  <!--Main Content-->
  <div class="flex-1 ">

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 my-8"> <!--THIS IS THE FOR THE DASHBORAD PLAY AROUND-->
    <div class="bg-orange-100 p-6 rounded-lg shadow border-t-4 border-pink-300">
      <p class="text-rose-700 uppercase text-xs font-bold">Ingredients</p>
      <p class="text-3xl font-bold"><%= @stats[:ingredients] %></p>
      <%= link_to "View all →", ingredients_path, class: "text-xs text-pink-700 hover:underline mt-2 block" %>
    </div>
    <div class="bg-orange-100 p-6 rounded-lg shadow border-t-4 border-pink-400">
      <p class="text-rose-700 uppercase text-xs font-bold">Recipes</p>
      <p class="text-3xl font-bold"><%= @stats[:recipes] %></p>
      <%= link_to "View all →", recipes_path, class: "text-xs text-pink-700 hover:underline mt-2 block" %>
    </div>
    <div class="bg-orange-100 p-6 rounded-lg shadow border-t-4 border-pink-500">
      <p class="text-rose-700 uppercase text-xs font-bold">Inventory Items</p>
      <p class="text-3xl font-bold"><%= @stats[:inventory] %></p>
      <%= link_to "View all →", inventory_items_path, class: "text-xs text-pink-700 hover:underline mt-2 block" %>
    </div>
    <div class="bg-orange-100 p-6 rounded-lg shadow border-t-4 border-pink-600">
      <p class="text-rose-700 uppercase text-xs font-bold">Total Batches</p>
      <p class="text-3xl font-bold"><%= @stats[:batches] %></p>
      <%= link_to "View all →", batches_path, class: "text-xs text-pink-700 hover:underline mt-2 block" %>
    </div>
  </div>

  <div class="flex flex-col md:flex-row gap-8">
    <!-- Recent Recipes -->
    <div class="flex-1">
      <div class="flex justify-between items-center mb-4 mt-5"> <!--flex justify-between items-center mb-4-->
        <h2 class="font-bold text-3xl text-white mb-3">Recent Recipes</h2>
        <%= link_to "New Recipe", new_recipe_path, class: "text-sm bg-white border border:rose-200 text-rose-900 px-3 py-1 rounded-full hover:bg-rose-900 hover:text-white" %>
      </div>
      <div class="bg-emerald-800 shadow rounded-lg divide-y">
        <% @recent_recipes.each do |recipe| %>
          <div class="p-4 flex justify-between items-center bg-rose-200 rounded-lg mb-3">
            <div>
              <%= link_to recipe.title, recipe, class: "text-pink-700 hover:underline font-medium" %>
              <p class="text-xs text-bold text-rose-900"><%= recipe.product_type %></p>
            </div>
            <span class="text-sm text-rose-800 "><%= recipe.created_at.strftime("%b %d") %></span>
          </div>
        <% end %>
        <% if @recent_recipes.empty? %>
          <div class="p-8 text-center bg-rose-200 rounded-lg">
            <p class=" text-rose-400 mb-4">No recipes yet.</p>
            <%= link_to "Create your first recipe", new_recipe_path, class: "text-pink-600 font-medium hover:underline" %>
          </div>
        <% end %>
      </div>
    </div>

     <!--Favourite Recipes-->
     <div class="flex-1 ">
  <div class="flex justify-between items-center mb-4 mt-5">
    <h2 class="font-bold text-3xl text-white mb-3">⭐ My Favourite Recipes</h2>
  </div>

  <div class="bg-emerald-800 shadow rounded-lg divide-y">
    <% @favourite_recipes.each do |recipe| %>
      <div class="p-4 flex justify-between items-center bg-yellow-600 mb-3 rounded-lg">
        <div>
          <%= link_to recipe.title, recipe_path(recipe), class: "font-medium text-pink-50 hover:underline" %>
          <p class="text-xs text-orange-50"><%= recipe.product_type %></p>
        </div>
      </div>
    <% end %>

    <% if @favourite_recipes.empty? %>
      <div class="p-8 text-center bg-yellow-600 rounded-lg">
        <p class="text-white">You haven't favourited any recipes yet.</p>
      </div>
    <% end %>
  </div>
</div>

    <!-- Recent Batches --> 
    <div class="flex-1">
      <div class="flex justify-between items-center mb-4 mt-5"> <!--flex justify-between items-center mb-4-->
        <h2 class="font-bold text-3xl text-white mb-3">Recent Batches</h2>
        <%= link_to "Log Batch", new_batch_path, class: "text-sm bg-white border border:rose-200 text-rose-900 w-auto px-3 py-1 rounded-full  hover:bg-rose-900 hover:text-white" %>
      </div>
      <div class="bg-emerald-800 shadow rounded-lg divide-y">
        <% @recent_batches.each do |batch| %>
          <div class="p-4 flex justify-between items-center bg-rose-900 mb-3 rounded-lg">
            <div>
              <p class="font-medium text-rose-200"><%= batch.recipe.title %></p>
              <p class="text-xs text-white italic"><%= batch.notes.truncate(40) if batch.notes.present? %></p>
            </div>
            <div class="text-right">
              <span class="text-sm text-white block"><%= batch.made_on.strftime("%b %d") %></span>
              <%= link_to "Details", batch, class: "text-xs font-bold text-yellow-600 hover:underline" %>
            </div>
          </div>
        <% end %>
        <% if @recent_batches.empty? %>
          <div class="p-8 text-center bg-rose-900 rounded-lg">
            <p class="text-rose-200 mb-4">No batches logged yet.</p>
            <%= link_to "Log your first batch", new_batch_path, class: "text-white font-medium hover:underline" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>
  <!-- Quick Actions -->
  <div class=" mb-40 bg-emerald-300 p-8 rounded-2xl border-4 border-frame border-white">
    <h2 class=" font-serif font-bold text-xl mb-6 text-center text-white tracking-widest">Quick Actions</h2>
    <div class="flex flex-wrap justify-center gap-4">
      <%= link_to "Add New Ingredient", new_ingredient_path, class: "bg-pink-300 border border-rose-200 px-6 py-3 rounded-xl shadow-sm hover:shadow-lg transition-all font-medium text-white" %>
      <%= link_to "Record Purchase", new_inventory_item_path, class: "bg-pink-400 border border-rose-200 px-6 py-3 rounded-xl shadow-sm hover:shadow-lg transition-all font-medium text-white" %>
      <%= link_to "Create Recipe", new_recipe_path, class: "bg-pink-500 border border-rose-200 px-6 py-3 rounded-xl shadow-sm hover:shadow-lg transition-all font-medium text-white" %>
      <%= link_to "Log Production", new_batch_path, class: "bg-pink-600 border border-rose-200 px-6 py-3 rounded-xl shadow-sm hover:shadow-lg transition-all font-medium text-white" %>
    </div>
  </div>

</div>