<% content_for :title, "Batches" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 text-green-500 font-medium rounded-lg inline-block mb-5" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl text-white">Batch History</h1>
    <%= link_to "Log New Batch", new_batch_path, class: "bg-white hover:bg-gray-200 text-rose-900 border border-rose-900 hover:border-rose-800 rounded-lg py-3 px-5 block font-medium" %>
  </div>

  <div id="batches" class="min-w-full mt-8 mb-3 grid grid-cols-1 md:grid-cols-2 gap-6">
    <% @batches.each do |batch| %>
      <div class="bg-rose-900 shadow rounded-lg p-6 border-l-4 border-rose-500">
        <div class="flex justify-between items-start">
          <div>
            <h2 class="font-bold text-xl text-rose-200"><%= batch.recipe.title %></h2>
            <p class="text-sm text-white"><%= batch.made_on.strftime("%B %d, %Y") %></p>
          </div>
          <%= link_to "View Details", batch, class: "text-sm text-yellow-600 font-bold hover:underline" %>
        </div>
        
        <% if batch.notes.present? %>
          <div class="mt-4 text-white italic text-sm">
            "<%= batch.notes.truncate(100) %>"
          </div>
        <% end %>
      </div>
    <% end %>
    
    <% if @batches.empty? %>
      <p class="text-rose-200 bg-rose-800 rounded-lg text-center">No batches logged yet. Go make something!</p>
    <% end %>
  </div>
</div>