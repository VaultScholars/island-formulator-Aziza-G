<% content_for :title, "Showing recipe" %>

<div class="max-w-4xl mx-auto p-6">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-4xl text-white font-bold font-serif text-gray-900 bg-pink-800 border border-pink-200 border-3 rounded-lg -ml-20 pl-5 tracking-tighter "><%= @recipe.title %></h1>
      <span class="inline-block bg-green-100 text-green-800 text-xs -ml-20 px-6 py-1 rounded-full mt-2 font-semibold uppercase tracking-wide">
        <%= @recipe.product_type %>
      </span>
    </div>
    <div class="flex gap-2 mt-6">
  <%= link_to "Edit this recipe", edit_recipe_path(@recipe), class: "rounded-lg ml-10 py-3 px-5 bg-orange-200  hover:text-orange-400 hover:bg-white inline-block font-medium" %>
  <%= link_to "Back to recipes", recipes_path, class: "rounded-lg ml-4 py-3 px-5 text-white bg-rose-900 hover:text-rose-900 hover:bg-white inline-block font-medium" %>
  
  <%# Add this button to quickly log a batch from the recipe page %>
  <%= link_to "Log a New Batch", new_batch_path(recipe_id: @recipe.id), 
      class: "rounded-lg ml-4 py-3 px-5 bg-green-300 text-white hover:text-green-600 hover:bg-gray-100 inline-block font-medium" %>
</div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="md:col-span-1">
      <% if @recipe.photo.attached? %>
        <%= image_tag @recipe.photo, class: "w-64 h-auto object-cover rounded-xl ml-9 shadow-lg border border-2 border-white" %>
      <% else %>
        <div class="w-full h-64 bg-gray-200 rounded-xl ml-9 px-2 py-2 flex items-center justify-center border border-frame border-3 border-gray-100 text-gray-400 italic">
          No photo uploaded
        </div>
      <% end %>
      
      <div class="mt-8 bg-white p-6 rounded-xl shadow-sm border border-gray-100 pl-7 pr-5 py-7 -ml-20">
        <h2 class="text-xl font-bold mb-4 text-pink-800 border-b pb-2 ">Ingredients</h2>
        <ul class="space-y-3">
          <% @recipe.recipe_ingredients.each do |ri| %>
            <li class="flex justify-between items-center">
              <span class="font-medium text-gray-700"><%= ri.ingredient.name %></span>
              <span class="text-gray-500 bg-gray-100 px-2 py-3 rounded text-sm "><%= ri.quantity %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="md:col-span-2 ml-5">
      <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 h-full">
        <h2 class="text-2xl font-bold mb-4 text-pink-800 underline">Method</h2>
        <div class="prose prose-green max-w-none text-gray-700 leading-relaxed">
          <%= simple_format @recipe.method %>
        </div>
      </div>
    </div>
  </div>
</div>