<% content_for :title, "Editing inventory item" %>

<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl text-white underline">Edit Inventory Item</h1>

  <%= render "form", inventory_item: @inventory_item %>

  <%= link_to "Show this item", @inventory_item, class: "ml-2 rounded-lg py-3 px-5 bg-orange-200 hover:bg-orange-300 inline-block font-medium" %>
  <%= link_to "Back to inventory", inventory_items_path, class: "ml-2 rounded-lg py-3 px-5 bg-orange-200 hover:bg-orange-300 inline-block font-medium" %>
</div>
